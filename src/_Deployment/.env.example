# ====================================================================
# BizFirst MinIO Deployment - Environment Configuration
# ====================================================================
# Copy this file to .env and fill in your actual values
# Do NOT commit .env with real credentials to version control
# ====================================================================

# ====================================================================
# MINIO PRIMARY STORAGE - Production Data
# ====================================================================
# Credentials for the primary MinIO instance running on Server A
MINIO_ROOT_USER=bizfirst
MINIO_ROOT_PASSWORD=change-me-to-strong-password

# ====================================================================
# BACKUP & RECOVERY CONFIGURATION
# ====================================================================
# Restic password for encrypting all backups
# This password is required to restore from any backup
# Keep this safe - without it, backups cannot be recovered
RESTIC_PASSWORD=change-me-to-strong-password

# MinIO Replica Endpoint (Server B - Backup Server)
# Where backups will be stored via restic
# Format: hostname or IP address (port 9000 is assumed)
# Example: backup-server.example.com or 192.168.1.100
MINIO_REPLICA_ENDPOINT=backup-server

# ====================================================================
# POSTGRESQL CONFIGURATION
# ====================================================================
# Database server details for PostgreSQL backups
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB_NAME=bizfirst_db

# ====================================================================
# SQL SERVER CONFIGURATION
# ====================================================================
# Database server details for SQL Server backups
# Note: Only SA (System Administrator) account is supported for backups
SQLSERVER_HOST=sqlserver
SQLSERVER_PORT=1433
SQLSERVER_PASSWORD=change-me-sqlserver-password
SQLSERVER_DB_NAME=BizFirstDB

# ====================================================================
# OPTIONAL: DOCKER NETWORKS
# ====================================================================
# These networks must already exist before starting the deployment
# Create with: docker network create network_QA
#              docker network create network_Demo
# Network names can be customized in docker-compose.minio.yml
# NETWORK_QA=network_QA
# NETWORK_DEMO=network_Demo

# ====================================================================
# SCHEDULING & RETENTION (Configure in ofelia.ini)
# ====================================================================
# Default backup schedule: 2:00 AM daily
# - MinIO backup: 2:00 AM
# - SQL Server backup: 2:10 AM
# - PostgreSQL backup: 2:20 AM
#
# Default retention:
# - Keep 7 daily backups
# - Keep 4 weekly backups
# - Keep 12 monthly backups
#
# Modify ofelia.ini to change schedules and retention policies
